  .matrix { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 8px; }
  .matrix-box { border-radius: 10px; padding: 14px 16px; }
  .m-green { background: #e8f8ef; border-left: 4px solid #1d9e75; }
  .m-blue { background: #e8f2ff; border-left: 4px solid #3a8fe8; }
  .m-amber { background: #fff5e0; border-left: 4px solid #e8a020; }
