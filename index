    <div class="sec-header">
      <h2>10 Target Partnership Companies</h2>
      <p>Researched and prioritized based on product fit, user overlap, and realistic collaboration potential.</p>
    </div>

    <!-- 1. Razorpay -->
    <div class="card">
      <div class="card-top">
        <div class="avatar" style="background:#ddeeff; color:#1155aa;">RZ</div>
        <div>
          <div class="card-title">Razorpay</div>
